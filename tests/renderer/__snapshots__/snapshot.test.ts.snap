// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`renderSource snapshots > matches dashboard grid 1`] = `"<div class="uis-frame" data-viewport="tablet" data-theme="adaptive" data-background="default" style="width: 768px; max-width: 100%;"><div class="uis-root"><div class="uis-grid" style="display: grid; grid-template-areas: "nav nav" "side main"; grid-template-columns: 180px 1fr; grid-template-rows: 56px 1fr;"><div class="uis-grid__cell" style="grid-area: nav;"><div class="uis-navbar"><div class="uis-navbar__brand">Dash</div><div class="uis-navbar__items"></div></div></div><div class="uis-grid__cell" style="grid-area: side;"><div class="uis-card"><div class="uis-card__title">Menu</div></div></div><div class="uis-grid__cell" style="grid-area: main;"><div class="uis-card"><div class="uis-card__title">Main</div></div></div></div></div></div>"`;

exports[`renderSource snapshots > matches minimal 1`] = `"<div class="uis-frame" data-viewport="desktop" data-theme="adaptive" data-background="default" style="width: 1200px; max-width: 100%;"><div class="uis-root"><div class="uis-flow"><div class="uis-navbar"><div class="uis-navbar__brand">MyApp</div><div class="uis-navbar__items"><div class="uis-navbar__item">Home</div><div class="uis-navbar__item">Docs</div></div></div><div class="uis-row" style="gap: 12px;"><div class="uis-card"><div class="uis-card__title">Hi</div></div></div></div></div></div>"`;
